# Backend environment variables
MONGO_URI=mongodb://localhost:27017/agrilens
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_HOURS=24
UPLOAD_FOLDER=uploads

# Twilio Verify
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_MOCK_MODE=true

# Firebase Storage
FIREBASE_CREDENTIALS_PATH=
FIREBASE_STORAGE_BUCKET=

# Inter-service URLs
DETECTION_SERVICE_URL=http://localhost:5001
FORECAST_SERVICE_URL=http://localhost:5002

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW=600
VERIFY_RATE_LIMIT_MAX=5
VERIFY_RATE_LIMIT_WINDOW=600
