# Backend environment variables
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_HOURS=24
MEDIA_STORAGE_PROVIDER=cloudinary
UPLOAD_FOLDER=uploads

# Video analysis pipeline (FR-5)
VIDEO_FRAME_INTERVAL_SEC=2
VIDEO_MAX_FRAMES=20
VIDEO_BLUR_THRESHOLD=80.0
VIDEO_MIN_FRAMES_REQUIRED=1
VIDEO_SAVE_DEBUG_FRAMES=false

# Cloudinary scan media storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio Verify + SMS
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_MOCK_MODE=true

# Firebase Cloud Messaging Admin SDK for notification-service only
# Docker compose mounts ./secrets to /app/secrets inside containers.
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json

# Inter-service URLs
DETECTION_SERVICE_URL=http://localhost:5001
FORECAST_SERVICE_URL=http://localhost:5002
DETECTION_MOCK_FALLBACK=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# Weather
OPENWEATHER_API_KEY=your-openweather-key
OPENWEATHER_API_URL=https://api.openweathermap.org/data/3.0/onecall
OPENWEATHER_FALLBACK_URL=https://api.openweathermap.org/data/2.5/onecall

# Rate Limiting
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW=600
VERIFY_RATE_LIMIT_MAX=5
VERIFY_RATE_LIMIT_WINDOW=600
