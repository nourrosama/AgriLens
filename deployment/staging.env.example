# Copy these values into your server environment or project-level .env before
# starting the staging stack. Do not commit real secret values.

APP_ENV=demo
NGINX_HTTP_PORT=8080
CORS_ALLOWED_ORIGINS=https://your-staging-domain.example
FORCE_HTTPS=false
JSON_LOGS=true

MEDIA_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Demo staging keeps OTP mocked until Twilio is paid/enabled.
TWILIO_MOCK_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json

AWS_S3_BUCKET=
AWS_S3_PREFIX=models
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MODEL_BASE_URL=
